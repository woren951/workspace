[Unit]
Description=Main service

[Service]
ExecStartPre=systemctl enable /etc/systemd/web/asdf.service
ExecStartPre=systemctl enable /etc/systemd/web/nginx.service

ExecStart=bash /opt/main.sh
Restart=no
Type=oneshot
TimeoutStartSec=infinity
RemainAfterExit=yes
PassEnvironment=PATH
PassEnvironment=ASDF_DIR
PassEnvironment=ASDF_DATA_DIR
PassEnvironment=LOCALHTTPS_DATA

[Install]
WantedBy=multi-user.target
