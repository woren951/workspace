[Unit]
Description=Main service

[Service]
# ExecStartPre=cp -r /home/web/.web-shared/. /home/web/
# ExecStartPre=trust anchor --store ${LOCALHTTPS_DATA}/CertificationAuthorities/default.pem
ExecStartPre=systemctl enable /etc/systemd/web/asdf.service
ExecStartPre=systemctl enable /etc/systemd/web/nginx.service

ExecStart=bash /opt/main.sh
Restart=no
Type=oneshot
TimeoutStartSec=infinity
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
